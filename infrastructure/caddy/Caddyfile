{
  email {$CADDY_EMAIL}
}

{$API_DOMAIN} {
  # Security headers applied to all responses from this domain.
  header {
    # Prevent MIME-type sniffing
    X-Content-Type-Options nosniff
    # Deny framing entirely (API only — no legitimate embed use case)
    X-Frame-Options DENY
    # Strict HSTS: 2 years, include subdomains, preload-eligible
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    # Tighten referrer leakage
    Referrer-Policy strict-origin-when-cross-origin
    # Disable browser features that have no use on an API endpoint
    Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
    # CSP for the admin HTML page; API JSON responses are unaffected.
    # unsafe-inline is required because the admin SPA uses inline scripts and styles.
    # connect-src 'self' allows fetch/XHR requests to the same origin.
    # img-src 'self' data: allows images and data URIs for previews.
    Content-Security-Policy "default-src 'none'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self';"
    # Remove identifying server headers
    -Server
    -X-Powered-By
    # X-XSS-Protection intentionally omitted: deprecated in modern browsers,
    # and can cause issues in some configurations. CSP provides better XSS protection.
  }

  # public contact form API endpoint (from roitsystems.ca)
  @contact-api path /api/contact /api/contact/*
  handle @contact-api {
    reverse_proxy contact-inbox-api:3000
  }

  # corporate-network dashboard (root)
  @network-root path /corporate-network /corporate-network/
  handle @network-root {
    uri strip_prefix /corporate-network
    reverse_proxy contact-inbox-api:3000
  }

  # corporate-network contact routes (admin interface, internal only)
  @contact path /corporate-network/contact /corporate-network/contact/*
  handle @contact {
    uri strip_prefix /corporate-network/contact
    reverse_proxy contact-inbox-api:3000
  }

  # corporate-network image-converter routes
  @image-converter path /corporate-network/image-converter /corporate-network/image-converter/*
  handle @image-converter {
    uri strip_prefix /corporate-network/image-converter
    reverse_proxy image-converter-api:3000
  }

  # shared health check (contact-inbox) at root
  @health path /health
  handle @health {
    reverse_proxy contact-inbox-api:3000
  }

  # Block everything else
  handle {
    respond "This is a private API endpoint. Public site: https://roitsystems.ca" 404
  }
}
