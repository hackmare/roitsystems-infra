# RO IT Systems Infrastructure — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Domain ────────────────────────────────────────────────────────────────────
# Public hostname for the API (no trailing slash)
API_DOMAIN=api.roitsystems.ca

# Email for Caddy's ACME/Let's Encrypt TLS certificate
CADDY_EMAIL=m.oger@roitsystems.ca

# HTTP Basic auth gate for every /corporate-network page and tool.
# Generate the hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'change-me-strong-password'
CORPORATE_NETWORK_AUTH_USER=admin
CORPORATE_NETWORK_AUTH_HASH=$2a$14$replace-with-caddy-hash-password-output

# ── CouchDB ───────────────────────────────────────────────────────────────────
COUCHDB_USER=admin
COUCHDB_PASSWORD=change-me-strong-password

# ── NATS ──────────────────────────────────────────────────────────────────────
# Internal only — no public exposure needed

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://roitsystems.ca

# Secret token for the /api/admin/* endpoints (generate with: openssl rand -hex 32)
ADMIN_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Rate limiting: max submissions per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=900000

# ── Worker ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# Optional: webhook URL for future notifications (Signal/Telegram/email relay)
# Leave empty to disable
NOTIFICATION_WEBHOOK_URL=

# ── Notification Service ──────────────────────────────────────────────────────
# Claude API key for message analysis
CLAUDE_API_KEY=change-me-your-claude-api-key

# Resend API key for email notifications
RESEND_API_KEY=change-me-your-resend-api-key

# Email recipient for contact message notifications
NOTIFICATION_EMAIL=m.oger@roitsystems.ca

# Email sender address (must be verified in Resend)
NOTIFICATION_FROM_EMAIL=notifications@roitsystems.ca

# Twilio SMS configuration (optional, leave empty to skip SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
