# RO IT Systems Infrastructure — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Domain ────────────────────────────────────────────────────────────────────
# Public hostname for the API (no trailing slash)
API_DOMAIN=api.roitsystems.ca

# Email for Caddy's ACME/Let's Encrypt TLS certificate
CADDY_EMAIL=m.oger@roitsystems.ca

# ── CouchDB ───────────────────────────────────────────────────────────────────
COUCHDB_USER=admin
COUCHDB_PASSWORD=change-me-strong-password

# ── NATS ──────────────────────────────────────────────────────────────────────
# Internal only — no public exposure needed

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://roitsystems.ca

# Secret token for the /api/admin/* endpoints (generate with: openssl rand -hex 32)
ADMIN_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Rate limiting: max submissions per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=900000

# ── Worker ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# Optional: webhook URL for future notifications (Signal/Telegram/email relay)
# Leave empty to disable
NOTIFICATION_WEBHOOK_URL=
